---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Stats from '../components/Stats.astro';
import 'photoswipe/style.css'
---

<Layout title="HomelabARR - Open Homelab Platform">
	<main>
		<nav class="navigation">
			<div class="nav-links">
				<a href="/pricing" class="nav-link">Pricing</a>
				<a href="https://docs.homelabarr.com" class="nav-link">Docs</a>
				<a href="https://github.com/smashingtags/homelabarr" class="nav-link">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
						<path d="M9 18c-4.51 2-5-2-7-2" />
					</svg>
					<span>GitHub</span>
				</a>
				<a href="https://discord.gg/Pc7mXX786x" class="nav-link">
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="9" cy="12" r="1" />
						<circle cx="15" cy="12" r="1" />
						<path d="M7.5 7.5c3.5-1 5.5-1 9 0" />
						<path d="M7.5 16.5c3.5 1 5.5 1 9 0" />
						<path d="M15.5 17c0 1 1.5 3 2 3 1.5 0 2.833-1.667 3.5-3 .667-1.667.5-5.833-1.5-11.5-1.457-1.015-3-1.34-4.5-1.5l-1 2.5" />
						<path d="M8.5 17c0 1-1.356 3-1.832 3-1.429 0-2.698-1.667-3.333-3-.635-1.667-.476-5.833 1.428-11.5C6.151 4.485 7.545 4.16 9 4l1 2.5" />
					</svg>
					<span>Discord</span>
				</a>
			</div>
		</nav>

		<div class="header">
			<h1><span class="text-gradient">HomelabARR</span></h1>
			<p class="tagline">The Open Homelab Platform</p>
			<p class="subtagline">Docker-native. Community-driven. No lock-in.</p>
			<div class="cta-buttons">
				<a href="https://github.com/smashingtags/homelabarr" class="primary-button">
					Download CE Free
				</a>
				<a href="#pricing" class="secondary-button">
					Get PE $99
				</a>
			</div>
		</div>

		<section class="editions">
			<div class="edition-grid">
				<div class="edition ce">
					<div class="edition-badge">CE</div>
					<h3>Community Edition</h3>
					<p class="price">Free</p>
					<ul>
						<li>Docker container management</li>
						<li>137+ pre-configured apps</li>
						<li>Real-time monitoring</li>
						<li>Community support</li>
						<li>Open source</li>
					</ul>
					<a href="https://github.com/smashingtags/homelabarr" class="edition-cta">Download Free</a>
				</div>
				<div class="edition pe">
					<div class="edition-badge recommended">PE</div>
					<h3>Professional Edition</h3>
					<p class="price">$99</p>
					<ul>
						<li>Everything in CE, plus:</li>
						<li>Theme Marketplace</li>
						<li>Plugin Ecosystem</li>
						<li>Priority support</li>
						<li>Lifetime updates</li>
					</ul>
					<a href="#buy" class="edition-cta primary">Buy Now</a>
				</div>
			</div>
		</section>

		<section class="comparison">
			<h2>Why HomelabARR?</h2>
			<table class="compare-table">
				<thead>
					<tr>
						<th>Feature</th>
						<th>HomelabARR</th>
						<th>HexOS</th>
						<th>Unraid</th>
						<th>TrueNAS</th>
					</tr>
				</thead>
				<tbody>
					<tr>
						<td>Open Source</td>
						<td class="yes">✓</td>
						<td class="no">✗</td>
						<td class="partial">Partial</td>
						<td class="yes">✓</td>
					</tr>
					<tr>
						<td>Docker Native</td>
						<td class="yes">✓</td>
						<td class="no">Jails/VMs</td>
						<td class="yes">✓</td>
						<td class="no">Limited</td>
					</tr>
					<tr>
						<td>Creator Marketplace</td>
						<td class="yes">✓</td>
						<td class="no">✗</td>
						<td class="no">✗</td>
						<td class="no">✗</td>
					</tr>
					<tr>
						<td>Hardware Agnostic</td>
						<td class="yes">✓</td>
						<td class="yes">✓</td>
						<td class="yes">✓</td>
						<td class="partial">Limited</td>
					</tr>
					<tr>
						<td>Price</td>
						<td class="price-cell">Free / $99</td>
						<td class="price-cell">$199</td>
						<td class="price-cell">$59-129</td>
						<td class="price-cell">Free / Enterprise</td>
					</tr>
				</tbody>
			</table>
		</section>

		<section class="features">
			<h2>Features</h2>
			<div class="feature-grid">
				<div class="feature">
					<h3>🚀 One-click Deployment</h3>
					<p>Deploy 137+ applications with a single click. No YAML required.</p>
				</div>
				<div class="feature">
					<h3>📊 Real-time Monitoring</h3>
					<p>Monitor container stats, health, and logs in real-time.</p>
				</div>
				<div class="feature">
					<h3>🎨 Theme Marketplace</h3>
					<p>Customize your dashboard with community-created themes.</p>
				</div>
				<div class="feature">
					<h3>🔌 Plugin Ecosystem</h3>
					<p>Extend functionality with plugins from the community.</p>
				</div>
			</div>
		</section>

		<Stats 
			githubRepo="smashingtags/homelabarr"
			discordInvite="Pc7mXX786x"
		/>

		<ul role="list" class="link-card-grid">
			<Card
				href="https://github.com/smashingtags/homelabarr"
				title="GitHub Repository"
				body="Access the source code and contribute to the project."
			/>
			<Card
				href="https://demo.homelabarr.com"
				title="Live Demo"
				body="Try HomelabARR with our interactive demo."
			/>
			<Card
				href="https://discord.gg/Pc7mXX786x"
				title="Join our Discord"
				body="Get help and connect with the community."
			/>
		</ul>
	</main>
</Layout>

<style>
	.navigation {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		backdrop-filter: blur(20px);
		background: rgba(19, 21, 26, 0.8);
		z-index: 100;
		padding: 1rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.1);
	}
	.nav-links {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: flex-end;
		gap: 1.5rem;
	}
	.nav-link {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: #fff;
		text-decoration: none;
		font-size: 0.9rem;
		opacity: 0.8;
		transition: opacity 0.2s ease;
	}
	.nav-link:hover {
		opacity: 1;
	}
	.header {
		text-align: center;
		padding: 8rem 0 2rem;
	}
	.tagline {
		font-size: 2rem;
		color: #fff;
		margin: 0.5rem 0;
		font-weight: 600;
	}
	.subtagline {
		font-size: 1.2rem;
		color: rgba(255,255,255,0.7);
		margin-bottom: 2rem;
	}
	.cta-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
	}
	.primary-button, .secondary-button {
		padding: 0.8rem 2rem;
		border-radius: 100px;
		font-weight: 500;
		font-size: 1.1rem;
		text-decoration: none;
		transition: all 0.2s ease;
	}
	.primary-button {
		background: rgb(var(--accent));
		color: white;
	}
	.primary-button:hover {
		background: rgb(var(--accent-light));
	}
	.secondary-button {
		background: rgba(255, 255, 255, 0.1);
		color: white;
	}
	.secondary-button:hover {
		background: rgba(255, 255, 255, 0.2);
	}
	.editions {
		margin: 4rem 0;
		padding: 2rem;
	}
	.edition-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
		max-width: 900px;
		margin: 0 auto;
	}
	.edition {
		padding: 2rem;
		background: rgba(255, 255, 255, 0.05);
		border-radius: 16px;
		border: 2px solid rgba(var(--accent-light), 0.2);
		text-align: center;
	}
	.edition.pe {
		border-color: rgb(var(--accent));
		background: rgba(var(--accent), 0.1);
	}
	.edition-badge {
		display: inline-block;
		padding: 0.5rem 1rem;
		background: rgba(255,255,255,0.1);
		border-radius: 20px;
		font-size: 0.9rem;
		margin-bottom: 1rem;
	}
	.edition-badge.recommended {
		background: rgb(var(--accent));
		color: white;
	}
	.edition h3 {
		color: rgb(var(--accent-light));
		margin-bottom: 0.5rem;
	}
	.edition .price {
		font-size: 2.5rem;
		font-weight: 700;
		margin: 1rem 0;
	}
	.edition ul {
		list-style: none;
		padding: 0;
		text-align: left;
		margin: 1.5rem 0;
	}
	.edition li {
		padding: 0.5rem 0;
		border-bottom: 1px solid rgba(255,255,255,0.1);
	}
	.edition-cta {
		display: block;
		padding: 1rem;
		background: rgba(255,255,255,0.1);
		color: white;
		text-decoration: none;
		border-radius: 8px;
		margin-top: 1rem;
		transition: background 0.2s;
	}
	.edition-cta:hover {
		background: rgba(255,255,255,0.2);
	}
	.edition-cta.primary {
		background: rgb(var(--accent));
	}
	.edition-cta.primary:hover {
		background: rgb(var(--accent-light));
	}
	.comparison {
		margin: 4rem 0;
		padding: 2rem;
		background: rgba(var(--accent-dark), 0.1);
		border-radius: 16px;
	}
	.comparison h2 {
		text-align: center;
		font-size: 2rem;
		margin-bottom: 2rem;
		color: rgb(var(--accent-light));
	}
	.compare-table {
		width: 100%;
		border-collapse: collapse;
	}
	.compare-table th,
	.compare-table td {
		padding: 1rem;
		text-align: left;
		border-bottom: 1px solid rgba(255,255,255,0.1);
	}
	.compare-table th {
		color: rgb(var(--accent-light));
	}
	.compare-table .yes {
		color: #4ade80;
		font-weight: 600;
	}
	.compare-table .no {
		color: #f87171;
	}
	.compare-table .partial {
		color: #fbbf24;
	}
	.features {
		margin-top: 4rem;
		padding: 2rem;
	}
	.features h2 {
		text-align: center;
		font-size: 2rem;
		margin-bottom: 2rem;
		color: rgb(var(--accent-light));
	}
	.feature-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 2rem;
	}
	.feature {
		padding: 1.5rem;
		background: rgba(255, 255, 255, 0.05);
		border-radius: 8px;
		border: 1px solid rgba(var(--accent-light), 0.2);
	}
	.feature h3 {
		color: rgb(var(--accent-light));
		margin-bottom: 0.5rem;
	}
	main {
		margin: auto;
		padding: 0;
		width: 1200px;
		max-width: calc(100% - 2rem);
		color: white;
		font-size: 20px;
		line-height: 1.6;
	}
	h1 {
		font-size: 5rem;
		font-weight: 800;
		line-height: 1;
		margin: 0;
	}
	.text-gradient {
		background-image: var(--accent-gradient);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}
	.link-card-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(24ch, 1fr));
		gap: 1.5rem;
		padding: 0;
		margin: 2rem 0;
	}
</style>
